# ============================================================
# BLITE PMS — Backend Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Server
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed CORS origins.
# In production set both the custom domain and Vercel URL, e.g.:
# FRONTEND_URL=https://manage.blite.in,https://blite-pms.vercel.app
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Service role key bypasses RLS — keep this SECRET, only use server-side

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Leegality (e-Sign)
LEEGALITY_BASE_URL=https://sandbox.leegality.com/api/v3.0
LEEGALITY_API_TOKEN=your_leegality_api_token_here

# WhatsApp / MSG91
MSG91_AUTH_KEY=your_msg91_key_here
MSG91_SENDER_ID=BLITE
MSG91_WHATSAPP_TEMPLATE_RENT_REMINDER=your_template_id

# PDF Generation
PDF_STORAGE_BUCKET=rent-deeds
KYC_STORAGE_BUCKET=kyc-documents
MAINTENANCE_STORAGE_BUCKET=maintenance
